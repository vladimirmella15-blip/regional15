# Admin panel password (change before production!)
ADMIN_PASSWORD=your_secure_password_here

# AI para el chatbot dinámico (opcional - https://console.groq.com)
# Sin esto, el chatbot solo responde preguntas predefinidas
AI_API_KEY=
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_MODEL=llama-3.3-70b-versatile

# SMTP para el formulario de contacto
# Usa Gmail: smtp.gmail.com, puerto 587, tu correo y contraseña de aplicación
# Usa Outlook: smtp-mail.outlook.com, puerto 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO=contacto@regional15.edu.do
